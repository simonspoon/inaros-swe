{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill|ReportFindings|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/review-marker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-review-gate.sh"
          }
        ]
      }
    ]
  }
}
